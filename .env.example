# ─────────────────────────────────────────────────────────────
# Atalaya OSINT Platform v2.0 — Environment Configuration
# State-grade intelligence collection, analysis, and reporting
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
APP_NAME=Atalaya
APP_VERSION=2.0.0
ENVIRONMENT=development       # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# ── Security ─────────────────────────────────────────────────
# Generate with: python scripts/generate_keys.py
SECRET_KEY=CHANGE_ME_generate_with_script
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ─────────────────────────────────────
POSTGRES_USER=atalaya
POSTGRES_PASSWORD=atalaya_pass
POSTGRES_DB=atalaya_db
DATABASE_URL=postgresql+asyncpg://atalaya:atalaya_pass@localhost:5432/atalaya_db
SYNC_DATABASE_URL=postgresql://atalaya:atalaya_pass@localhost:5432/atalaya_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secure_pass
REDIS_URL=redis://:redis_secure_pass@localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ── Neo4j (Graph Database) ────────────────────────────────────
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j_pass
NEO4J_URI=bolt://localhost:7687

# ── Qdrant (Vector Store) ─────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=atalaya_evidence
QDRANT_EMBEDDING_DIM=1536

# ── Kafka (Event Streaming) ──────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_EVENTS_TOPIC=atalaya-events
KAFKA_ALERTS_TOPIC=atalaya-alerts
KAFKA_CONSUMER_GROUP=atalaya-backend

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── LLM: Ollama (local, free) ─────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1
OLLAMA_ENABLED=true

# ── LLM: OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ── LLM: Anthropic ────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001

# ── LLM: OpenRouter ───────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.1-8b-instruct:free

LLM_FALLBACK_CHAIN=ollama,openai,anthropic,openrouter
LLM_MAX_RETRIES=3
LLM_REQUEST_TIMEOUT=120

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHATS=

# ── Storage ───────────────────────────────────────────────────
EVIDENCE_STORAGE_PATH=/var/atalaya/evidence
REPORTS_STORAGE_PATH=/var/atalaya/reports
LOGS_PATH=/var/atalaya/logs

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_API_PER_MINUTE=120
RATE_LIMIT_LOGIN_PER_HOUR=10

# ── Brute Force Protection ───────────────────────────────────
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_LOCKOUT_SECONDS=300
BRUTE_FORCE_IP_MAX_ATTEMPTS=20
BRUTE_FORCE_IP_LOCKOUT_SECONDS=900

# ── Password Policy ──────────────────────────────────────────
PASSWORD_MIN_LENGTH=12

# ── Session ──────────────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=30
MAX_CONCURRENT_SESSIONS=5

# ── Advanced Security ────────────────────────────────────────
ENABLE_MTLS=false
MTLS_CA_CERT_PATH=
ENABLE_WAF_HEADERS=true
ENABLE_CSRF=false

# ── Secret Rotation ──────────────────────────────────────────
SECRET_ROTATION_HOURS=72
AUTO_ROTATE_API_KEYS=false

# ── Audit ────────────────────────────────────────────────────
AUDIT_HASH_CHAIN=true
AUDIT_WORM_STORAGE=false
AUDIT_RETENTION_DAYS=3650

# ── Classification ───────────────────────────────────────────
DEFAULT_CLASSIFICATION=UNCLASSIFIED
CLASSIFICATION_LABELS=UNCLASSIFIED,CUI,CONFIDENTIAL,SECRET,TOP_SECRET

# ── Observability ────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=atalaya-backend
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ── Backup ───────────────────────────────────────────────────
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_RETENTION_DAYS=90

# ── Grafana Monitoring ───────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana_admin

# ── Multi-Tenant ─────────────────────────────────────────────
MULTI_TENANT=false
DEFAULT_TENANT_ID=default

# ── Optional OSINT Integrations ──────────────────────────────
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
HUNTER_IO_API_KEY=
URLSCAN_API_KEY=
IPINFO_TOKEN=
SECURITYTRAILS_API_KEY=
HIBP_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=

# ── Dark Web ──────────────────────────────────────────────────
TOR_PROXY_URL=socks5://127.0.0.1:9050
DARK_WEB_ENABLED=false

# ── GEOINT ────────────────────────────────────────────────────
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
MAPBOX_TOKEN=

# ── FININT ────────────────────────────────────────────────────
BLOCKCHAIN_API_KEY=
ETHERSCAN_API_KEY=

# ── Cyber Threat Intelligence ─────────────────────────────────
MISP_URL=
MISP_API_KEY=
OTX_API_KEY=
VULN_INTEL_API_KEY=

# ── STIX/TAXII ────────────────────────────────────────────────
TAXII_SERVER_URL=
TAXII_USERNAME=
TAXII_PASSWORD=

# ── Tool Rate Limits ─────────────────────────────────────────
DNS_RATE_LIMIT=30
WHOIS_RATE_LIMIT=10
WEB_FETCH_RATE_LIMIT=20
WEB_SEARCH_RATE_LIMIT=10
CERT_SEARCH_RATE_LIMIT=20
SOCIAL_RATE_LIMIT=30
IP_GEO_RATE_LIMIT=45
ARCHIVE_RATE_LIMIT=10
