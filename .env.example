# ─────────────────────────────────────────────────────────────
# Atalaya OSINT Platform — Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
APP_NAME=Atalaya
APP_VERSION=0.1.0
ENVIRONMENT=development       # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# ── Security ─────────────────────────────────────────────────
# Generate with: python scripts/generate_keys.py
SECRET_KEY=CHANGE_ME_generate_with_script
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://atalaya:atalaya_pass@localhost:5432/atalaya_db
# Sync URL for Alembic migrations
SYNC_DATABASE_URL=postgresql://atalaya:atalaya_pass@localhost:5432/atalaya_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Storage ───────────────────────────────────────────────────
EVIDENCE_STORAGE_PATH=/var/atalaya/evidence
REPORTS_STORAGE_PATH=/var/atalaya/reports

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── LLM: Ollama (local, free) ─────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1
# Set to true to enable Ollama as a provider
OLLAMA_ENABLED=true

# ── LLM: OpenAI ───────────────────────────────────────────────
# Leave blank to disable
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ── LLM: Anthropic ────────────────────────────────────────────
# Leave blank to disable
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001

# ── LLM: OpenRouter ───────────────────────────────────────────
# Leave blank to disable
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.1-8b-instruct:free

# LLM fallback chain (comma-separated, tried in order)
LLM_FALLBACK_CHAIN=ollama,openai,anthropic,openrouter

# ── Vector Store (Qdrant) ─────────────────────────────────────
QDRANT_URL=http://localhost:6333
# Leave blank to use in-memory mode (no persistence)
QDRANT_API_KEY=

# ── Telegram Bot ──────────────────────────────────────────────
# Leave blank to disable Telegram integration
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric chat IDs allowed to control the bot
TELEGRAM_ALLOWED_CHATS=

# ── Optional Integrations ────────────────────────────────────
# Each key enables additional OSINT sources.
# Platform remains fully functional without any of these.

# Shodan — internet-connected device search
SHODAN_API_KEY=

# VirusTotal — malware and threat intelligence
VIRUSTOTAL_API_KEY=

# Hunter.io — email discovery
HUNTER_API_KEY=

# Have I Been Pwned — data breach search
HIBP_API_KEY=

# ipinfo.io — enhanced IP geolocation
IPINFO_API_KEY=

# URLScan.io — website scanning
URLSCAN_API_KEY=

# Censys — internet asset discovery
CENSYS_API_ID=
CENSYS_API_SECRET=

# SecurityTrails — historical DNS data
SECURITYTRAILS_API_KEY=

# ── Rate Limiting ────────────────────────────────────────────
# Requests per minute per tool
DNS_RATE_LIMIT=30
WHOIS_RATE_LIMIT=10
WEB_FETCH_RATE_LIMIT=20
WEB_SEARCH_RATE_LIMIT=10
CERT_SEARCH_RATE_LIMIT=20
SOCIAL_RATE_LIMIT=30
IP_GEO_RATE_LIMIT=45
ARCHIVE_RATE_LIMIT=10
